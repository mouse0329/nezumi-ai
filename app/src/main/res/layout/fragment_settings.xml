<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/bg_session_list" android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">

            <ImageButton android:id="@+id/back_button" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_back_button" android:contentDescription="@string/back" android:src="@drawable/ic_back" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="@string/action_settings" android:textColor="@color/text_primary" android:textSize="22sp" android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" app:cardBackgroundColor="@color/surface_card" app:cardCornerRadius="16dp">

            <androidx.compose.ui.platform.ComposeView android:id="@+id/theme_mode_compose_view" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" app:cardBackgroundColor="@color/surface_card" app:cardCornerRadius="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/hf_token_title" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" />

                <TextView android:id="@+id/hf_auth_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/hf_auth_not_linked" android:textColor="@color/text_secondary" android:textSize="13sp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton android:id="@+id/hf_oauth_login_button" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/hf_oauth_login" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/hf_oauth_logout_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="@string/hf_oauth_logout" />
                </LinearLayout>

                <EditText android:id="@+id/hf_token_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:hint="@string/hf_token_hint" android:inputType="textNoSuggestions" android:maxLines="1" />

                <com.google.android.material.button.MaterialButton android:id="@+id/save_hf_token_button" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/hf_token_save" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/surface_card" app:cardCornerRadius="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/inference_title" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/context_window_label" android:textColor="@color/text_primary" android:textSize="13sp" />
                    <EditText android:id="@+id/context_window_input" android:layout_width="60dp" android:layout_height="40dp" android:layout_marginStart="8dp" android:inputType="number" android:text="4096" android:textColor="@color/text_primary" android:textSize="13sp" android:padding="8dp" />
                </LinearLayout>

                <TextView android:id="@+id/context_window_info" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/context_window_hint" android:textColor="@color/text_secondary" android:textSize="11sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/context_compression_switch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/context_compression_label" />

                <TextView android:id="@+id/context_compression_threshold_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/text_secondary" android:textSize="12sp" />

                <SeekBar android:id="@+id/context_compression_threshold_seek" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:max="45" android:progress="20" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/backend_label" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" />

                <com.google.android.material.button.MaterialButtonToggleGroup android:id="@+id/backend_toggle_group" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" app:singleSelection="true" app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton android:id="@+id/backend_cpu_button" style="@style/Widget.Nezumiai.Button.Toggle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="84dp" android:text="@string/backend_cpu" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/backend_gpu_button" style="@style/Widget.Nezumiai.Button.Toggle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="84dp" android:text="@string/backend_gpu" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/backend_npu_button" style="@style/Widget.Nezumiai.Button.Toggle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="84dp" android:text="@string/backend_npu" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/temperature_label" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" />

                <EditText android:id="@+id/temperature_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:hint="@string/temperature_hint" android:inputType="numberDecimal" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/topk_label" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" />

                <EditText android:id="@+id/topk_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:hint="@string/topk_hint" android:inputType="number" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/max_tokens_label" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" />

                <EditText android:id="@+id/max_tokens_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:hint="@string/max_tokens_hint" android:inputType="number" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/user_name_label" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" />

                <EditText android:id="@+id/user_name_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:hint="@string/user_name_hint" android:inputType="text" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/system_prompt_label" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" />

                <EditText android:id="@+id/system_prompt_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:hint="@string/system_prompt_hint" android:inputType="textMultiLine" android:minLines="3" android:maxLines="6" />

                <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/speculative_decoding_switch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="投機的デコーディング（高速化）" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="推論の高速化を有効にします（実験的機能）" android:textColor="@color/text_secondary" android:textSize="11sp" />

                <com.google.android.material.button.MaterialButton android:id="@+id/save_inference_button" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/save_inference" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/surface_card" app:cardCornerRadius="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gemma 4 2B" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" />

                <TextView android:id="@+id/gemma4_2b_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="未ダウンロード" android:textColor="@color/text_secondary" android:textSize="13sp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton android:id="@+id/download_gemma4_2b_button" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ダウンロード" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/delete_gemma4_2b_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="削除" />
                </LinearLayout>

                <ProgressBar android:id="@+id/gemma4_2b_download_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:max="100" android:visibility="gone" />

                <TextView android:id="@+id/gemma4_2b_download_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/text_secondary" android:textSize="12sp" android:visibility="gone" />

                <com.google.android.material.button.MaterialButton android:id="@+id/gemma4_2b_access_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/open_hf_approval_page" android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/surface_card" app:cardCornerRadius="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gemma 4 4B" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" />

                <TextView android:id="@+id/gemma4_4b_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="未ダウンロード" android:textColor="@color/text_secondary" android:textSize="13sp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton android:id="@+id/download_gemma4_4b_button" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ダウンロード" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/delete_gemma4_4b_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="削除" />
                </LinearLayout>

                <ProgressBar android:id="@+id/gemma4_4b_download_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:max="100" android:visibility="gone" />

                <TextView android:id="@+id/gemma4_4b_download_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/text_secondary" android:textSize="12sp" android:visibility="gone" />

                <com.google.android.material.button.MaterialButton android:id="@+id/gemma4_4b_access_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/open_hf_approval_page" android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/surface_card" app:cardCornerRadius="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gemma 3n E2B" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" />

                <TextView android:id="@+id/e2b_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="未ダウンロード" android:textColor="@color/text_secondary" android:textSize="13sp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton android:id="@+id/download_e2b_button" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ダウンロード" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/delete_e2b_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="削除" />
                </LinearLayout>

                <ProgressBar android:id="@+id/e2b_download_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:max="100" android:visibility="gone" />

                <TextView android:id="@+id/e2b_download_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/text_secondary" android:textSize="12sp" android:visibility="gone" />

                <com.google.android.material.button.MaterialButton android:id="@+id/e2b_access_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/open_hf_approval_page" android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/surface_card" app:cardCornerRadius="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gemma 3n E4B" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" />

                <TextView android:id="@+id/e4b_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="未ダウンロード" android:textColor="@color/text_secondary" android:textSize="13sp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton android:id="@+id/download_e4b_button" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ダウンロード" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/delete_e4b_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="削除" />
                </LinearLayout>

                <ProgressBar android:id="@+id/e4b_download_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:max="100" android:visibility="gone" />

                <TextView android:id="@+id/e4b_download_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/text_secondary" android:textSize="12sp" android:visibility="gone" />

                <com.google.android.material.button.MaterialButton android:id="@+id/e4b_access_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/open_hf_approval_page" android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/surface_card" app:cardCornerRadius="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/imported_task_title" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" />

                <TextView android:id="@+id/imported_task_empty_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/imported_task_empty" android:textColor="@color/text_secondary" android:textSize="13sp" />

                <LinearLayout android:id="@+id/imported_task_list_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton android:id="@+id/import_task_button" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/import_task_model" />

        <LinearLayout android:id="@+id/import_task_progress_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="vertical" android:visibility="gone">

            <ProgressBar android:id="@+id/import_task_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:indeterminate="true" />

            <TextView android:id="@+id/import_task_status_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/import_task_loading" android:textColor="@color/text_secondary" android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton android:id="@+id/license_page_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/open_license_page" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

