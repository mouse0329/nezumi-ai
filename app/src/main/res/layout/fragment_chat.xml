<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/bg_chat">

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">

        <!-- Chat Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical" android:background="@color/surface_card">

            <ImageButton android:id="@+id/back_button" android:layout_width="36dp" android:layout_height="36dp" android:scaleType="centerInside" android:src="@drawable/ic_back" android:background="@drawable/bg_back_button" android:contentDescription="@string/back" />

            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_app_icon_72" android:contentDescription="@string/app_name" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:scaleType="centerInside" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="10dp">

                <TextView android:id="@+id/chat_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/chat_title" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" android:ellipsize="end" android:singleLine="true" />

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/model_dropdown_layout" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="@string/model_dropdown_hint">

                    <AutoCompleteTextView android:id="@+id/model_dropdown" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="none" android:focusable="false" android:clickable="true" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:gravity="end" android:orientation="vertical">

                <com.google.android.material.button.MaterialButton android:id="@+id/compress_context_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minHeight="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:text="@string/compress_context" android:textSize="12sp" app:cornerRadius="14dp" />

                <com.google.android.material.button.MaterialButton android:id="@+id/chat_no_thinking_toggle" style="@style/Widget.Nezumiai.Button.Outlined.Thinking" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:checkable="true" android:minHeight="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:text="@string/chat_thinking_follow_settings" android:textSize="11sp" android:visibility="gone" app:cornerRadius="14dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:background="@color/surface_card">

            <TextView android:id="@+id/context_meter_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="12sp" />

            <ProgressBar android:id="@+id/context_meter_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:max="1000" android:progressTint="@color/context_meter_progress" android:progressBackgroundTint="@color/context_meter_track" />

            <TextView android:id="@+id/resource_usage_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/text_secondary" android:textSize="12sp" android:visibility="gone" />
        </LinearLayout>

        <!-- Messages RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/messages_recycler_view" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="12dp" android:paddingBottom="12dp" android:clipToPadding="false" />

        <LinearLayout android:id="@+id/response_typing_indicator" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="8dp" android:visibility="gone">

            <ProgressBar android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/response_typing_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/response_generating" android:textSize="13sp" android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_horizontal" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingBottom="6dp">

            <com.google.android.material.button.MaterialButton android:id="@+id/scroll_to_bottom_button" style="@style/Widget.Nezumiai.Button.Outlined" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/scroll_to_bottom_icon" android:textSize="12sp" android:visibility="gone" android:minHeight="0dp" android:insetTop="0dp" android:insetBottom="0dp" app:cornerRadius="14dp" />
        </LinearLayout>

        <!-- Input Bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical" android:background="@color/surface_card">

            <!-- Media Menu Button -->
            <com.google.android.material.button.MaterialButton android:id="@+id/media_menu_button" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="40dp" android:layout_height="40dp" android:minWidth="0dp" android:minHeight="0dp" android:text="+" android:textSize="20sp" android:contentDescription="@string/add_media_menu" android:insetTop="0dp" android:insetBottom="0dp" />

            <com.nezumi_ai.presentation.ui.widget.ClipboardAwareEditText android:id="@+id/message_input" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="@string/enter_message" android:textSize="14sp" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:background="@drawable/bg_input_field" android:padding="10dp" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:imeOptions="actionSend" />

            <com.google.android.material.button.MaterialButton android:id="@+id/send_button" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="56dp" android:text="@string/send_icon" style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/model_loading_overlay" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone" android:clickable="true" android:focusable="true" android:gravity="center" android:orientation="vertical" android:background="@color/loading_overlay">

        <ProgressBar android:layout_width="48dp" android:layout_height="48dp" android:layout_marginBottom="16dp" />

        <TextView android:id="@+id/model_loading_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/model_loading" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary" />
    </LinearLayout>
</FrameLayout>
